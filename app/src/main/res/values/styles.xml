<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.QFix" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/electric_blue</item>
        <item name="colorPrimaryVariant">@color/electric_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/emerald_green</item>
        <item name="colorSecondaryVariant">@color/emerald_green_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Background color -->
        <item name="android:windowBackground">@color/soft_off_white</item>
    </style>
    
    <!-- Splash screen theme -->
    <style name="Theme.QFix.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/electric_blue_dark</item>
    </style>
    
    <!-- Text styles -->
    <style name="TextAppearance.QFix.Display" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">28sp</item>
    </style>
    
    <style name="TextAppearance.QFix.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
    </style>
    
    <style name="TextAppearance.QFix.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="TextAppearance.QFix.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="TextAppearance.QFix.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
    </style>
    
    <style name="TextAppearance.QFix.Mono" parent="TextAppearance.MaterialComponents.Body2">
        <item name="fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
    </style>
    
    <!-- Button styles -->
    <style name="Widget.QFix.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="Widget.QFix.Button.ElectricBlue" parent="Widget.QFix.Button">
        <item name="backgroundTint">@color/electric_blue</item>
    </style>
    
    <style name="Widget.QFix.Button.EmeraldGreen" parent="Widget.QFix.Button">
        <item name="backgroundTint">@color/emerald_green</item>
    </style>
    
    <style name="Widget.QFix.Button.Ghost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">56dp</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/electric_blue</item>
    </style>
</resources>
