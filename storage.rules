rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Citizens can upload complaint photos
    match /complaint-photos/{complaintId}/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                   request.resource.size < 10 * 1024 * 1024 && // 10MB max
                   request.resource.contentType.matches('image/.*');
    }
    
    // Authorities can upload resolution photos
    match /resolution-photos/{complaintId}/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'authority' &&
                   request.resource.size < 10 * 1024 * 1024 && // 10MB max
                   request.resource.contentType.matches('image/.*');
    }
    
    // Users can upload profile photos
    match /profile-photos/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId &&
                   request.resource.size < 5 * 1024 * 1024 && // 5MB max
                   request.resource.contentType.matches('image/.*');
    }
  }
}